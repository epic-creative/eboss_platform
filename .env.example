# Runtime environment.
# Expected values: local, stage, prod.
EBOSS_ENV=local

# Phoenix listener.
# This is the port Bandit/Phoenix binds to locally or in a container.
PORT=4000

# Public app URL.
# These values drive Phoenix endpoint URLs, auth links, and default canonical-host behavior.
PUBLIC_HOST=local.eboss.ai
PUBLIC_SCHEME=http
PUBLIC_PORT=4000
# PUBLIC_URL=http://local.eboss.ai:4000

# Canonical-host redirects.
# By default, the canonical host should match PUBLIC_HOST.
# CANONICAL_HOST_PASSTHROUGH_HOSTS accepts a comma-separated list with no spaces.
CANONICAL_HOST_ENABLED=true
CANONICAL_HOST=local.eboss.ai
CANONICAL_HOST_PASSTHROUGH_HOSTS=

# LiveVue / Vite dev server.
# Keep these aligned with your local DNS host when using local.eboss.ai.
VITE_HOST=local.eboss.ai
VITE_SCHEME=http
VITE_PORT=5173
# VITE_ALLOWED_HOSTS=.eboss.ai,localhost,127.0.0.1

# Security.
# Generate with: mix phx.gen.secret
TOKEN_SIGNING_SECRET=replace-me-with-a-secret
