# Runtime environment.
# Expected values: local, stage, prod.
EBOSS_ENV=local

# Phoenix listener.
PORT=4000

# Public host.
# Local defaults to `local.eboss.ai`; set `PHX_HOST=localhost` if you want pure localhost URLs.
PHX_HOST=local.eboss.ai

# LiveVue / Vite dev server.
VITE_PORT=5173

# Security.
# Generate with: mix phx.gen.secret
TOKEN_SIGNING_SECRET=replace-me-with-a-secret
# Generate with: openssl rand -base64 32
EBOSS_CLOAK_KEY=replace-me-with-a-base64-32-byte-key

# Workspace chat providers.
# At least one key is required to use the real chat runtime outside MIX_ENV=test.
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-replace-me

# Production only.
# DATABASE_URL=ecto://postgres:postgres@localhost/eboss_prod
# SECRET_KEY_BASE=replace-me-with-a-secret
