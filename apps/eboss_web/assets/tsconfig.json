{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "lib": ["ES2015", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "*": ["./node_modules/*", "../../../deps/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client"]
  },
  "include": ["./js/**/*", "./vue/**/*", "../lib/eboss_web/**/*"],
  "exclude": ["node_modules"]
}
