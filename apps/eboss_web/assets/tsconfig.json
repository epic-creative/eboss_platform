{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "lib": ["ES2015", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "target": "ES2020",
    "paths": {
      "@/*": ["./*"],
      "*": ["./node_modules/*", "../../../deps/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client", "@histoire/plugin-vue/client"]
  },
  "include": [
    "./js/**/*",
    "./vue/**/*",
    "./tests/vue/**/*",
    "./histoire.config.ts",
    "./histoire.setup.ts",
    "./vitest.config.ts",
    "../lib/eboss_web/**/*"
  ],
  "exclude": ["node_modules"]
}
