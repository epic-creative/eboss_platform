{
  "scripts": {
    "histoire": "histoire dev --config histoire.config.ts --host 127.0.0.1 --port 6006",
    "histoire:build": "histoire build --config histoire.config.ts",
    "playwright:report": "npm exec --yes --package=playwright@1.59.1 playwright show-report test-results/playwright/report",
    "playwright:server:test": "cd .. && EBOSS_ENV=test PHX_HOST=localhost MIX_ENV=test mix phx.server",
    "playwright:setup": "cd .. && EBOSS_ENV=test PHX_HOST=localhost MIX_ENV=test mix eboss.playwright.setup",
    "playwright:smoke": "npm exec --yes --package=playwright@1.59.1 playwright test tests/playwright/smoke",
    "playwright:verify-setup": "npm exec --yes --package=playwright@1.59.1 playwright test tests/playwright/setup",
    "playwright:test": "npm exec --yes --package=playwright@1.59.1 playwright test",
    "vue:check": "vue-tsc --noEmit"
  },
