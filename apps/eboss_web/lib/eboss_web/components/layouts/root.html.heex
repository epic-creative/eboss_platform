<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="EBoss" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <PhoenixVite.Components.assets
      names={["js/app.js", "css/app.css"]}
      manifest={{:eboss_web, "priv/static/assets/.vite/manifest.json"}}
      dev_server={
        PhoenixVite.Components.has_vite_watcher?(EBossWeb.Endpoint) || Mix.env() == :test
      }
      to_url={fn path -> static_url(@conn, path) end}
    />
    <script>
      (() => {
        const listeners = new Set();

        const readTheme = () => {
          const stored = localStorage.getItem("phx:theme");
          return stored === "light" || stored === "dark" ? stored : "system";
        };

        const notify = (theme) => listeners.forEach((listener) => listener(theme));

        const commitTheme = (theme, {persist = true} = {}) => {
          if (theme === "light" || theme === "dark") {
            if (persist) localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          } else {
            if (persist) localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
            theme = "system";
          }

          notify(theme);
        };

        window.EBossTheme = {
          getTheme: () => readTheme(),
          setTheme: (theme) => commitTheme(theme),
          subscribe: (listener) => {
            listeners.add(listener);
            return () => listeners.delete(listener);
          },
        };

        if (!document.documentElement.hasAttribute("data-theme")) {
          commitTheme(readTheme(), {persist: false});
        }

        window.addEventListener("storage", (e) => {
          if (e.key === "phx:theme") {
            commitTheme(e.newValue || "system", {persist: false});
          }
        });

        window.addEventListener("phx:set-theme", (e) => {
          commitTheme(e.target.dataset.phxTheme || "system");
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
